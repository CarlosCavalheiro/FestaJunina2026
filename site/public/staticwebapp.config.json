{
  "routes": [
    { "route": "/admin",    "rewrite": "/admin/index.html" },
    { "route": "/admin/",   "rewrite": "/admin/index.html" },
    { "route": "/admin/login", "rewrite": "/admin/index.html" },
    { "route": "/admin/usuarios", "rewrite": "/admin/index.html" },
    { "route": "/admin/pedidos", "rewrite": "/admin/index.html" },
    { "route": "/admin/perguntas", "rewrite": "/admin/index.html" },
    { "route": "/admin/editar_evento", "rewrite": "/admin/index.html" },
    { "route": "/admin/dashboard", "rewrite": "/admin/index.html" },
    { "route": "/admin/lotes", "rewrite": "/admin/index.html" },
    { "route": "/Admin",    "redirect": "/admin", "statusCode": 301 },
    { "route": "/Admin/*",  "redirect": "/admin", "statusCode": 301 },
    { "route": "/portaria", "rewrite": "/portaria/index.html" },
    { "route": "/portaria/", "rewrite": "/portaria/index.html" },
    { "route": "/portaria/login", "rewrite": "/portaria/index.html" },
    { "route": "/portaria/QrCode", "rewrite": "/portaria/index.html" },
    { "route": "/portaria/HistoricoQr", "rewrite": "/portaria/index.html" },
    { "route": "/portaria/leitor", "rewrite": "/portaria/index.html" },
    { "route": "/Portaria", "redirect": "/portaria", "statusCode": 301 },
    { "route": "/Portaria/*", "redirect": "/portaria", "statusCode": 301 },
    { "route": "/pesquisa", "rewrite": "/pesquisa/index.html" },
    { "route": "/pesquisa/", "rewrite": "/pesquisa/index.html" },
    { "route": "/Pesquisa", "redirect": "/pesquisa", "statusCode": 301 },
    { "route": "/Pesquisa/*", "redirect": "/pesquisa", "statusCode": 301 }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/admin/*",
      "/portaria/*",
      "/pesquisa/*",
      "/*.{css,js,png,jpg,jpeg,svg,ico,json,woff,woff2,ttf,eot,map}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
